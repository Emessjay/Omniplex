# Omniplex environment variables.
#
# Copy to `.env.local` and fill in real values for local development.
# `.env.local` is gitignored — NEVER commit real secrets.
#
# The app is designed to build and run WITHOUT these set (the Supabase
# clients init lazily and only throw when actually used), so `npm run build`
# and `npx vitest run` work in CI without secrets.

# --- Supabase (public — safe to expose to the browser) ---
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# --- Supabase (server-only — service role, full DB access, NEVER expose) ---
SUPABASE_SERVICE_ROLE_KEY=

# --- Procedural universe ---
# Seed for deterministic galaxy generation. Same seed + coords => same planet.
# Choose any stable string; changing it re-rolls the entire universe.
WORLD_SEED=omniplex-dev

# --- Dev login (TESTING ONLY — server-only, OFF by default) ---
# Bypasses the magic-link email round-trip and logs you straight in as a fixed
# dev user. NEVER prefix with NEXT_PUBLIC_ (must stay server-side) and NEVER
# enable on a real/public deploy. Leave unset/empty for production.
# Set OMNIPLEX_DEV_LOGIN=1 to enable; OMNIPLEX_DEV_LOGIN_EMAIL is optional
# (defaults to dev@omniplex.local). Requires Supabase to be configured.
#OMNIPLEX_DEV_LOGIN=
#OMNIPLEX_DEV_LOGIN_EMAIL=
